# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# ── Email delivery ──────────────────────────────────────────────────────────
# Recipient address
EMAIL_TO=you@example.com

# Your Gmail address used to send the digest
SMTP_USER=you@gmail.com

# Gmail App Password (NOT your account password)
# Create one at: https://myaccount.google.com/apppasswords
# (Requires 2-Step Verification to be enabled on the account)
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Optional overrides (defaults shown)
# EMAIL_FROM=you@gmail.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# ───────────────────────────────────────────────────────────────────────────

# YouTube Data API v3 key (free)
# Get one at: https://console.cloud.google.com → APIs & Services → Credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# Anthropic API key (optional — only needed if using Option B in agent.py)
# Get one at: https://console.anthropic.com → API Keys
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# AWS credentials (optional — only needed if using Bedrock / Option A)
# Prefer: aws configure
# Or set manually:
# AWS_ACCESS_KEY_ID=your_key
# AWS_SECRET_ACCESS_KEY=your_secret
# AWS_DEFAULT_REGION=us-east-1
